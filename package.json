{
    "name": "@diia-inhouse/types",
    "version": "13.2.3",
    "type": "module",
    "description": "Core types",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "repository": "https://github.com/diia-open-source/be-types",
    "author": "Diia",
    "license": "SEE LICENCE IN LICENCE.md",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "npm run genproto && npx tsc && cp -r proto dist/proto",
        "semantic-release": "semantic-release",
        "lint": "oxlint && oxfmt --check . && buf format ./proto --diff --exit-code ",
        "lint-fix": "oxlint --fix && oxfmt . && buf format ./proto --write",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "find-circulars": "npx madge --circular --extensions ts ./",
        "genproto": "npx genproto --outputDir src/generated"
    },
    "dependencies": {
        "@bufbuild/protobuf": "2.12.0",
        "@types/node": "25.6.2",
        "type-fest": "4.40.0"
    },
    "devDependencies": {
        "@bufbuild/buf": "1.69.0",
        "@diia-inhouse/configs": "7.0.1",
        "@diia-inhouse/genproto": "4.0.3",
        "@diia-inhouse/oxc-config": "1.11.0",
        "lockfile-lint": "5.0.0",
        "oxfmt": "0.47.0",
        "oxlint": "1.62.0",
        "oxlint-tsgolint": "0.22.1",
        "rimraf": "6.1.3",
        "semantic-release": "24.2.3",
        "ts-proto": "2.11.8",
        "typescript": "5.9.3"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
